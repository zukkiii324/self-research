{
  "name": "Note Editorial Room",
  "description": "Note向けの記事制作を、役割分担された複数エージェントで進める編集体制。",
  "final_agent_id": "final_edit",
  "default_model_profile": "balanced",
  "model_profiles": {
    "fast_planning": {
      "model": "gpt-5.4-mini",
      "reasoning_effort": "medium",
      "notes": "戦略や構成など、素早い整理が欲しい工程向け"
    },
    "balanced": {
      "model": "gpt-5.4",
      "reasoning_effort": "medium",
      "notes": "標準的な企画・執筆工程向け"
    },
    "deep_research": {
      "model": "gpt-5.4",
      "reasoning_effort": "high",
      "notes": "リサーチ、レビュー、事実確認など精度優先の工程向け"
    },
    "polish": {
      "model": "gpt-5.4",
      "reasoning_effort": "medium",
      "notes": "最終編集や文体調整向け"
    }
  },
  "content_overrides": [
    {
      "match_any": [
        "医療",
        "法律",
        "税務",
        "投資",
        "金融",
        "薬機法",
        "健康",
        "最新",
        "ニュース"
      ],
      "profile_overrides": {
        "editor_in_chief": "deep_research",
        "research": "deep_research",
        "fact_review": "deep_research",
        "editorial_review": "deep_research",
        "final_edit": "deep_research"
      }
    }
  ],
  "agents": [
    {
      "id": "command_lead",
      "name": "指揮担当",
      "department": "Program",
      "mission": "記事制作全体の課題を整理し、優先度と責任分担を定めて進行を統率する。",
      "prompt_path": "prompts/command_lead.md",
      "deliverable": "課題管理と進行指示メモ",
      "dependencies": [],
      "model_profile": "deep_research"
    },
    {
      "id": "editor_in_chief",
      "name": "編集長",
      "department": "Editorial",
      "mission": "記事の勝ち筋、論点、品質基準を定義する。",
      "prompt_path": "prompts/editor_in_chief.md",
      "deliverable": "企画方針書",
      "dependencies": [
        "command_lead"
      ],
      "model_profile": "balanced"
    },
    {
      "id": "strategy",
      "name": "読者戦略担当",
      "department": "Strategy",
      "mission": "読者像、刺さる切り口、タイトル案を設計する。",
      "prompt_path": "prompts/strategy.md",
      "deliverable": "読者戦略メモ",
      "dependencies": [
        "command_lead",
        "editor_in_chief"
      ],
      "model_profile": "fast_planning"
    },
    {
      "id": "research",
      "name": "リサーチ担当",
      "department": "Research",
      "mission": "検証すべき論点、根拠不足箇所、追加取材項目を洗い出す。",
      "prompt_path": "prompts/research.md",
      "deliverable": "リサーチ計画",
      "dependencies": [
        "command_lead",
        "editor_in_chief",
        "strategy"
      ],
      "model_profile": "deep_research"
    },
    {
      "id": "outline",
      "name": "構成担当",
      "department": "Structure",
      "mission": "記事の章立てと論理展開を設計する。",
      "prompt_path": "prompts/outline.md",
      "deliverable": "記事構成案",
      "dependencies": [
        "command_lead",
        "editor_in_chief",
        "strategy",
        "research"
      ],
      "model_profile": "fast_planning"
    },
    {
      "id": "draft",
      "name": "ドラフト担当",
      "department": "Writing",
      "mission": "構成に沿って記事の初稿を書く。",
      "prompt_path": "prompts/draft.md",
      "deliverable": "記事初稿",
      "dependencies": [
        "command_lead",
        "editor_in_chief",
        "strategy",
        "research",
        "outline"
      ],
      "model_profile": "balanced"
    },
    {
      "id": "fact_review",
      "name": "事実レビュー担当",
      "department": "Quality",
      "mission": "事実性、根拠、鮮度、品質ゲート充足をレビューする。",
      "prompt_path": "prompts/fact_review.md",
      "deliverable": "事実レビュー指摘書",
      "dependencies": [
        "command_lead",
        "editor_in_chief",
        "strategy",
        "research",
        "outline",
        "draft"
      ],
      "model_profile": "deep_research"
    },
    {
      "id": "editorial_review",
      "name": "編集レビュー担当",
      "department": "Quality",
      "mission": "構成、重複、読みやすさ、スタイルガイド準拠をレビューする。",
      "prompt_path": "prompts/editorial_review.md",
      "deliverable": "編集レビュー指摘書",
      "dependencies": [
        "command_lead",
        "editor_in_chief",
        "strategy",
        "research",
        "outline",
        "draft"
      ],
      "model_profile": "balanced"
    },
    {
      "id": "final_edit",
      "name": "最終編集担当",
      "department": "Publishing",
      "mission": "レビューを反映し、公開可能な最終稿に仕上げる。",
      "prompt_path": "prompts/final_edit.md",
      "deliverable": "公開用最終稿",
      "dependencies": [
        "command_lead",
        "editor_in_chief",
        "strategy",
        "research",
        "outline",
        "draft",
        "fact_review",
        "editorial_review"
      ],
      "model_profile": "polish"
    }
  ]
}
